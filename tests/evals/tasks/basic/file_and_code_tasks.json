      {"type": "file_contains", "path": "calculator.py", "pattern": "def subtract"},
      {"type": "file_contains", "path": "calculator.py", "pattern": "def multiply"},
      {"type": "file_contains", "path": "calculator.py", "pattern": "def divide"},
      {"type": "tool_used", "tool": "write"}
    ],
    "expected_steps": 1,
    "timeout": 45,
    "rubric": "Class should have all four methods with correct implementation"
  },
  {
    "id": "code-003",
    "category": "code_writing",
    "difficulty": "medium",
